---
permalink: /feeds/docops-lab-blog.xml
layout: null
---
{%- assign posts = site.blog | where_exp: "p", "p.published != false and p.draft != true" | sort: "date" | reverse -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom"
      xmlns:media="http://search.yahoo.com/mrss/">
  <title type="html">{{ site.title }} Blog</title>
  <link href="{{ site.url }}/feeds/docops-lab-blog.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}/" rel="alternate" type="text/html"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}/feeds/docops-lab-blog.xml</id>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    <email>{{ site.author.email | xml_escape }}</email>
  </author>
  {%- for post in posts %}
  <entry>
    <title type="html">{{ post.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ post.url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    {%- if post.excerpt and post.excerpt != "" %}
    <summary type="html"><![CDATA[{{ post.excerpt | strip_html | strip }}]]></summary>
    {%- endif %}
    {%- if post.author %}
    <author><name>{{ post.author | xml_escape }}</name></author>
    {%- else %}
    <author>
      <name>{{ site.author.name | xml_escape }}</name>
      <email>{{ site.author.email | xml_escape }}</email>
    </author>
    {%- endif %}
    {%- if post.tags %}
    {%- for tag in post.tags %}
    <category term="{{ tag | xml_escape }}"/>
    {%- endfor %}
    {%- endif %}
    {%- if post.image and post.image != "" %}
    {%- if post.image contains "http" %}
    {%- assign img_url = post.image %}
    {%- else %}
    {%- assign img_url = post.image | prepend: "/" | prepend: site.url %}
    {%- endif %}
    <media:thumbnail url="{{ img_url }}"/>
    <media:content medium="image" url="{{ img_url }}"/>
    {%- endif %}
    <content type="html" xml:base="{{ site.url }}{{ post.url }}"><![CDATA[{{ post.content }}]]></content>
  </entry>
  {%- endfor %}
</feed>